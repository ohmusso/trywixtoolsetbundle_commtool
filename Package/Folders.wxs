<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
	<Fragment>
		<StandardDirectory Id="LocalAppDataFolder">
			<Directory Id="INSTALLFOLDER" Name="!(bind.Property.Manufacturer) !(bind.Property.ProductName)" />
		</StandardDirectory>

		<StandardDirectory Id="DesktopFolder" />
		
		<ComponentGroup Id="CleanupFolderComponents" Directory="INSTALLFOLDER">
			<Component Id="CleanupInstallFolder" Guid="*">
				<RegistryValue Root="HKCU" Key="Software\!(bind.Property.Manufacturer)\!(bind.Property.ProductName)" Name="installed" Type="integer" Value="1" KeyPath="yes" />
				<RemoveFolder Id="RemoveINSTALLFOLDER" On="uninstall" />
			</Component>
		</ComponentGroup>
	</Fragment>
</Wix>